{
  "manifest_version": 3,
  "name": "Study Note Dashboard V3 Stable",
  "version": "3.1.0",
  "key": "",
  "description": "Dashboard ghi chú học tập ổn định, có backup tự động và giữ dữ liệu qua các lần cập nhật.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Study Note",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
