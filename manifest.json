{
  "manifest_version": 3,
  "name": "Study Note Dashboard",
  "version": "3.7.2",
  "key": "",
  "description": "Workspace ghi chú học tập theo môn, chương, loại note; có Study Sprint, lịch ôn theo chu kỳ và backup tự động.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Study Note",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
